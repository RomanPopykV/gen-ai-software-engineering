{
  "name": "customer-support-ticket-system",
  "version": "1.0.0",
  "description": "Customer support ticket management system with multi-format import",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "pipeline": "node pipeline.js",
    "pipeline:researcher": "node pipeline.js -- --stage bug-researcher",
    "pipeline:verifier": "node pipeline.js -- --stage research-verifier",
    "pipeline:planner": "node pipeline.js -- --stage bug-planner",
    "pipeline:fixer": "node pipeline.js -- --stage bug-fixer",
    "pipeline:test-gen": "node pipeline.js -- --stage unit-test-generator",
    "pipeline:security": "node pipeline.js -- --stage security-verifier"
  },
  "keywords": [
    "support",
    "tickets",
    "customer-service"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "csv-parse": "^5.5.0",
    "express": "^4.18.2",
    "fast-xml-parser": "^4.3.2",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}
